# Root environment for docker-compose. Copy to `.env` and adjust as needed.
# `docker compose` automatically reads this file.

# ---- Database (shared by the db and backend services) ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=inventory

# ---- Backend ----
ENVIRONMENT=development
DEBUG=true
LOW_STOCK_THRESHOLD=10
# Origins allowed to call the API from a browser (the frontend container is :8080).
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# ---- Frontend (baked into the build) ----
VITE_API_BASE_URL=http://localhost:8000/api

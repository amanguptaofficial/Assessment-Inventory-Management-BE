# ---- Application ----
PROJECT_NAME=Inventory & Order Management API
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api

# ---- Database ----
# Either provide a full DATABASE_URL (Render/Railway give you one)...
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# ...or the individual parts used by docker-compose:
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=inventory

# ---- CORS (comma separated origins the browser frontend is served from) ----
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- Business rules ----
LOW_STOCK_THRESHOLD=10
